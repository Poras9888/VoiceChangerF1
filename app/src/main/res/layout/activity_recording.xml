<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_recording_gradient"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00:00"
            android:textColor="#FFFFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <com.voice.changer.sound.effects.recorder.ui.custom.WaveformView
            android:id="@+id/waveformView"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="16dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvNote1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="♪"
                android:textColor="#CCFFFFFF"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tvNote2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="♪"
                android:textColor="#CCFFFFFF"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tvNote3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="♪"
                android:textColor="#CCFFFFFF"
                android:textSize="20sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="horizontal">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabStop"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:animation="@anim/pulse_record"
                android:src="@android:drawable/ic_media_pause"
                app:backgroundTint="#FFFFFFFF"
                app:tint="#4A90E2" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabSave"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="18dp"
                android:alpha="0.7"
                android:src="@android:drawable/checkbox_on_background"
                app:backgroundTint="#FFFFFFFF"
                app:tint="#4A90E2" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
